# Copy this file to .env (gitignored) and fill in values before running the script.
# None of these are required — omit any that don't apply.

# Direct download URL for Cisco Packet Tracer DMG.
# Supports SharePoint sharing links (download=1 is appended automatically).
# If unset, the script resolves the URL from the GitHub release.
# PACKET_TRACER_DMG_URL=https://cloudmails-my.sharepoint.com/...

# Override the GitHub repo used to resolve release asset URLs.
# RELEASES_REPO=owner/repo

# Override the Blender DMG URL and version.
# BLENDER_DMG_URL=https://download.blender.org/release/Blender3.6/blender-3.6.23-macos-x64.dmg
# BLENDER_VERSION=3.6.23
